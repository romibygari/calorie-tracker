{
  "cli": {
    "version": ">= 8.0.0"
  },
  "build": {
    "development": {
      "developmentClient": true,
      "distribution": "internal"
    },
    "preview": {
      "android": {
        "buildType": "apk"
      },
      "distribution": "internal",
      "prebuildCommand": "npx expo prebuild --platform android --non-interactive && sed -i 's/gradle-[0-9.]*-all/gradle-8.3-all/g' android/gradle/wrapper/gradle-wrapper.properties"
    },
    "production": {
      "android": {
        "buildType": "app-bundle"
      }
    }
  }
}
